install.packages(c("BiocManager", "tidyverse", "renv"))
library(Biostrings)
library(ShortRead)
library(tidyverse)
fastq_file <- "data/barcode77.fastq"
output_file <- "results/qc/read_stats.csv"
chunk_size  <- 10000
cat("Reading FASTQ file in chunks...\n")
stream  <- FastqStreamer(fastq_file, n = chunk_size)
results <- list()
chunk_i <- 1
repeat {
fq <- yield(stream)
if (length(fq) == 0) break
cat("Processing chunk", chunk_i, "...\n")
seqs <- sread(fq)
gc <- rowSums(alphabetFrequency(seqs, baseOnly = TRUE)[, c("G","C")]) / width(seqs) * 100
rl <- width(seqs)
mq <- sapply(as(quality(fq), "IntegerList"), mean)
results[[chunk_i]] <- tibble(
read_id      = as.character(id(fq)),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
}
mq <- rowMeans(as(quality(fq), "matrix"), na.rm = TRUE)
mq <- sapply(as(quality(fq), "PhredQuality"), function(q) mean(as.integer(chartr(paste(rawToChar(as.raw(33:126)), collapse=""), paste(0:93, collapse=""), as.character(q)))))
results[[chunk_i]] <- tibble(
read_id      = as.character(id(fq)),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
repeat {
fq <- yield(stream)
if (length(fq) == 0) break
cat("Processing chunk", chunk_i, "...\n")
seqs <- sread(fq)
gc <- rowSums(alphabetFrequency(seqs, baseOnly = TRUE)[, c("G","C")]) / width(seqs) * 100
rl <- width(seqs)
mq <- sapply(as(quality(fq), "PhredQuality"), function(q) mean(as.integer(chartr(paste(rawToChar(as.raw(33:126)), collapse=""), paste(0:93, collapse=""), as.character(q)))))
results[[chunk_i]] <- tibble(
read_id      = as.character(id(fq)),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
}
close(stream)
final <- bind_rows(results)
write_csv(final, output_file)
cat("Done! Total reads:", nrow(final), "\n")
cat("Results saved to:", output_file, "\n")
head(read.csv("results/qc/read_stats.csv"))
results[[chunk_i]] <- tibble(
read_id      = sub(" .*", "", as.character(id(fq))),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
library(Biostrings)
library(ShortRead)
library(tidyverse)
fastq_file <- "data/barcode77.fastq"
output_file <- "results/qc/read_stats.csv"
chunk_size  <- 5000
cat("Reading FASTQ file in chunks...\n")
stream  <- FastqStreamer(fastq_file, n = chunk_size)
results <- list()
chunk_i <- 1
repeat {
fq <- yield(stream)
if (length(fq) == 0) break
cat("Processing chunk", chunk_i, "...\n")
seqs <- sread(fq)
gc <- rowSums(alphabetFrequency(seqs, baseOnly = TRUE)[, c("G","C")]) /
width(seqs) * 100
rl  <- width(seqs)
# Quality: ASCII - 33 = Phred score
mq <- sapply(seq_len(length(fq)), function(i) {
mean(as.integer(utf8ToInt(as.character(quality(fq[i])))) - 33L)
})
results[[chunk_i]] <- tibble(
read_id      = sub(" .*", "", as.character(id(fq))),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
}
library(Biostrings)
library(ShortRead)
library(tidyverse)
fastq_file <- "data/barcode77.fastq"
output_file <- "results/qc/read_stats.csv"
chunk_size  <- 5000
cat("Reading FASTQ file in chunks...\n")
stream  <- FastqStreamer(fastq_file, n = chunk_size)
results <- list()
chunk_i <- 1
repeat {
fq <- yield(stream)
if (length(fq) == 0) break
cat("Processing chunk", chunk_i, "...\n")
seqs <- sread(fq)
gc <- rowSums(alphabetFrequency(seqs, baseOnly = TRUE)[, c("G","C")]) /
width(seqs) * 100
rl  <- width(seqs)
# Quality: ASCII - 33 = Phred score
mq <- sapply(seq_len(length(fq)), function(i) {
mean(as(quality(fq[i]), "IntegerList")[[1]], na.rm = TRUE)
})
results[[chunk_i]] <- tibble(
read_id      = sub(" .*", "", as.character(id(fq))),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
}
fq_test <- readFastq("data/barcode77.fastq", nread = 5)
class(quality(fq_test))
quality(fq_test[1])
mean(as.integer(chartr(rawToChar(as.raw(33:126)), rawToChar(as.raw(0:93)), as.character(quality(fq_test[1])[[1]]))))
q_str <- as.character(quality(fq_test[1])[[1]])
mean(utf8ToInt(q_str) - 33L)
# Quality: ASCII - 33 = Phred score
mq <- sapply(seq_len(length(fq)), function(i) {
q_str <- as.character(quality(fq[i])[[1]])
mean(utf8ToInt(q_str) - 33L)
})
library(Biostrings)
library(ShortRead)
library(tidyverse)
fastq_file <- "data/barcode77.fastq"
output_file <- "results/qc/read_stats.csv"
chunk_size  <- 5000
cat("Reading FASTQ file in chunks...\n")
stream  <- FastqStreamer(fastq_file, n = chunk_size)
results <- list()
chunk_i <- 1
repeat {
fq <- yield(stream)
if (length(fq) == 0) break
cat("Processing chunk", chunk_i, "...\n")
seqs <- sread(fq)
gc <- rowSums(alphabetFrequency(seqs, baseOnly = TRUE)[, c("G","C")]) /
width(seqs) * 100
rl  <- width(seqs)
# Quality: ASCII - 33 = Phred score
mq <- sapply(seq_len(length(fq)), function(i) {
q_str <- as.character(quality(fq[i])[[1]])
mean(utf8ToInt(q_str) - 33L)
})
results[[chunk_i]] <- tibble(
read_id      = sub(" .*", "", as.character(id(fq))),
read_length  = rl,
gc_content   = round(gc, 2),
mean_quality = round(mq, 2)
)
chunk_i <- chunk_i + 1
}
close(stream)
final <- bind_rows(results)
write_csv(final, output_file)
cat("Done! Total reads:", nrow(final), "\n")
cat("Results saved to:", output_file, "\n")
